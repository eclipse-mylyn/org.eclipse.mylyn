Bundle-Version: 4.11.0.qualifier
Bundle-Vendor: Eclipse Mylyn
Require-Bundle: org.eclipse.core.runtime;bundle-version="0.0.0",
 org.eclipse.jdt.ui;bundle-version="0.0.0",
 org.eclipse.jface;bundle-version="0.0.0",
 org.eclipse.jface.text;bundle-version="0.0.0",
 org.eclipse.mylyn.context.core;bundle-version="4.4.0",
 org.eclipse.mylyn.context.sdk.util;bundle-version="4.4.0",
 org.eclipse.mylyn.commons.sdk.util.junit5;bundle-version="4.11.0",
 org.eclipse.mylyn.ide.ant;bundle-version="4.4.0",
 org.eclipse.mylyn.ide.ui;bundle-version="4.4.0",
 org.eclipse.mylyn.resources.ui;bundle-version="4.4.0",
 org.eclipse.mylyn.team.ui;bundle-version="4.4.0",
 org.eclipse.ui.workbench;bundle-version="0.0.0"
Export-Package: org.eclipse.mylyn.ide.tests;x-internal:=true
Import-Package: org.junit.jupiter.api;version="[6.0.0,7.0.0)",
 org.junit.jupiter.api.extension;version="[6.0.0,7.0.0)",
 org.junit.platform.launcher;version="[6.0.0,7.0.0)",
 org.junit.platform.launcher.listeners;version="[6.0.0,7.0.0)",
 org.junit.platform.suite.api;version="[6.0.0,7.0.0)"
Bundle-RequiredExecutionEnvironment: JavaSE-21
